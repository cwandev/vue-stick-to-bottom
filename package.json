{
  "name": "vue-stick-to-bottom",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "description": "A lightweight Vue utility intended mainly for AI chat applications, for smoothly sticking to the bottom of messages.",
  "author": {
    "name": "Wang Chao",
    "url": "https://github.com/cwandev"
  },
  "license": "MIT",
  "homepage": "https://github.com/cwandev/vue-stick-to-bottom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cwandev/vue-stick-to-bottom.git"
  },
  "bugs": {
    "url": "https://github.com/cwandev/vue-stick-to-bottom/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "stick-to-bottom",
    "scroll",
    "chat",
    "auto-scroll",
    "scroll-to-bottom",
    "resizeobserver",
    "infinite-list",
    "ui"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    }
  },
  "main": "dist/index.es.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build:demo": "vite build",
    "preview:demo": "vite preview --host",
    "build:lib": "vite build -c vite.lib.config.ts",
    "prepublishOnly": "pnpm build:lib",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "release": "bumpp --commit --push --tag",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@iconify-json/ph": "^1.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.2",
    "lint-staged": "^16.2.7",
    "lorem-ipsum": "^2.0.8",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint --edit ${1}"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
